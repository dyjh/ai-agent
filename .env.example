# LLM 对话模型配置。默认使用 OpenAI-compatible 接口。
# 可填写 OpenAI、DashScope、OneAPI、LiteLLM 等兼容 /v1/chat/completions 的服务。
LLM_PROVIDER=openai_compatible
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# 本地 Ollama 对话模型示例：
# 如需启用，设置 LLM_PROVIDER=ollama，并确保本机已启动 ollama serve。
# LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# PostgreSQL 连接地址。无可用 PostgreSQL 时，运行时会回退到内存仓储，但 run/step 无法跨进程恢复。
DATABASE_URL=postgresql://agent:agent@localhost:5432/local_agent

# 知识库开关。provider 支持 qdrant、pinecone、openai。
USE_KONWAGE_BASE=true
KONWAGE_BASE_PROVIDER=qdrant

# Qdrant 向量库配置。Qdrant 只作为向量索引，不是知识库事实源。
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_KB=kb_chunks
QDRANT_COLLECTION_MEMORY=memory_chunks
QDRANT_COLLECTION_CODE=code_chunks
# 仅在明确接受删除并重建维度不匹配的非空 collection 时开启。
QDRANT_RECREATE_ON_DIMENSION_MISMATCH=false

# Pinecone 向量库配置。index_host 使用 Pinecone index 的 data-plane host。
PINECONE_INDEX_HOST=
PINECONE_API_KEY=
PINECONE_NAMESPACE_KB=kb_chunks
PINECONE_NAMESPACE_MEMORY=memory_chunks
PINECONE_NAMESPACE_CODE=code_chunks

# OpenAI Vector Stores 知识库配置。留空时 OPENAI_KB_API_KEY 会回退到 OPENAI_API_KEY。
OPENAI_KB_BASE_URL=https://api.openai.com/v1
OPENAI_KB_API_KEY=
OPENAI_VECTOR_STORE_KB=
OPENAI_VECTOR_STORE_MEMORY=
OPENAI_VECTOR_STORE_CODE=

# 知识库 / 记忆向量 embedding 配置。
# EMBEDDING_PROVIDER 支持 openai_compatible、ollama、fake。
# EMBEDDING_DIMENSION 必须与所选 embedding 模型输出维度一致。
# 如果切换 embedding 维度，请同步切换 collection 名称或重建旧 collection。
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# 本地 Ollama embedding 示例：
# nomic-embed-text 常见输出维度为 768，切换模型时请同步修改 EMBEDDING_DIMENSION。
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSION=768
